<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I'm So Sorry</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #fff0f3;
            text-align: center;
            transition: background 0.5s ease;
        }

        .container {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 90%;
        }

        h1 { color: #ff4d6d; }
        p { color: #590d22; font-size: 1.1rem; }

        .btn-group {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        button {
            padding: 10px 25px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: bold;
            transition: transform 0.2s;
        }

        #yesBtn { background-color: #ff4d6d; color: white; }
        #noBtn { background-color: #ced4da; color: #495057; }

        button:hover { transform: scale(1.1); }

        .hidden { display: none; }

        .cake-icon {
            font-size: 80px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <div class="container" id="card">
        <div id="apologySection">
            <h1>I'm Sorry! 🥺</h1>
            <p>I feel terrible about what happened. Can you ever forgive me?</p>
            <div class="btn-group">
                <button id="yesBtn" onclick="showCake()">Yes</button>
                <button id="noBtn" onmouseover="moveButton()">No</button>
            </div>
        </div>

        <div id="cakeSection" class="hidden">
            <div class="cake-icon">🎂</div>
            <h1>Yay! Thank You!</h1>
            <p>Since we're good now, here is a cake for you.</p>
            <button onclick="location.reload()" style="background: #ffb3c1; color: #590d22;">Eat Cake</button>
        </div>
    </div>

    <script>
        // Fun logic: The "No" button runs away when they try to click it!
        function moveButton() {
            const noBtn = document.getElementById('noBtn');
            const x = Math.random() * (window.innerWidth - noBtn.offsetWidth);
            const y = Math.random() * (window.innerHeight - noBtn.offsetHeight);
            
            noBtn.style.position = 'absolute';
            noBtn.style.left = x + 'px';
            noBtn.style.top = y + 'px';
        }

        // Switch to the cake view
        function showCake() {
            document.getElementById('apologySection').classList.add('hidden');
            document.getElementById('cakeSection').classList.remove('hidden');
            document.body.style.backgroundColor = "#ffccd5";
            
            // Add some confetti effect (optional)
            for(let i=0; i<50; i++) {
                createConfetti();
            }
        }

        // Just a little extra flair
        function createConfetti() {
            const confetti = document.createElement('div');
            confetti.innerText = "🌸";
            confetti.style.position = 'fixed';
            confetti.style.left = Math.random() * 100 + 'vw';
            confetti.style.top = '-20px';
            confetti.style.fontSize = Math.random() * 20 + 10 + 'px';
            confetti.style.zIndex = '999';
            document.body.appendChild(confetti);

            const animation = confetti.animate([
                { transform: 'translateY(0) rotate(0deg)', opacity: 1 },
                { transform: `translateY(100vh) rotate(${Math.random() * 360}deg)`, opacity: 0 }
            ], {
                duration: Math.random() * 3000 + 2000,
                easing: 'linear'
            });

            animation.onfinish = () => confetti.remove();
        }
    </script>
</body>
</html>
